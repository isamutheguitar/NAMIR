# ============================================================
# NAMIR 2026 Environment Variables Template
# ============================================================
# [JP] このファイルをコピーして「.env」にリネームし、各項目を書き換えてください。
# [EN] Copy this file to ".env" and fill in each value for your environment.
# (.env is ignored by Git via .gitignore)
# ============================================================

# 1. Google OAuth Client ID (for Login)
# [JP] Google Cloud Console > APIとサービス > 認証情報 で取得
# [EN] Get from: Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID_HERE"
# Vite frontend also needs the Client ID
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID_HERE"

# 2. Authorized Google Email Address
# [JP] このアドレス以外はログインを拒否します
# [EN] Only this email address will be allowed to log in.
AUTHORIZED_EMAIL="YOUR_GMAIL_ADDRESS_HERE"

# 3. Google Service Account (for Spreadsheet access)
# [JP] Google Cloud Console > IAMと管理 > サービス アカウント で取得
# [EN] Get from: Google Cloud Console > IAM & Admin > Service Accounts
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"

# Private Key: Ensure newlines are replaced with \n and enclosed in double quotes.
# [JP] 秘密鍵: 改行を \n に変換してダブルクォートで囲んでください
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# 4. Google Spreadsheet ID
# [JP] スプレッドシートURL: https://docs.google.com/spreadsheets/d/[THIS_PART]/edit
# [EN] The part of the spreadsheet URL between /d/ and /edit
GOOGLE_SHEET_ID="YOUR_SHEET_ID_HERE"

# 5. JWT Secret Key
# [JP] セッション暗号化用。以下コマンドで生成可能:
# [EN] For session encryption. Generate via: 
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="YOUR_RANDOM_SECRET_STRING_MIN_32_CHARS"