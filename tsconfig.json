{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "../shared/*": [
                "./shared/*"
            ]
        }
    },
    "include": [
        "api/**/*.ts",
        "shared/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "client",
        "server"
    ]
}